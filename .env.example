# Workflow Planner — local empty install
# Copy this file to .env
# Do NOT put production secrets here.

# Admin PIN (default 0000)
WORKFLOW_PIN=0000

PORT=8080

# Enables one-click update from GitHub on laptop
WORKFLOW_STARTER=1

# Optional: stable admin session (auto file .session_secret if empty)
# WORKFLOW_SESSION_SECRET=

# Optional brand override
# WORKFLOW_BRAND_NAME=Workflow Planner
# WORKFLOW_BRAND_TAGLINE=

# Optional custom DB (default: ./data/shoes.db)
# DB_PATH=

# Optional R2 — leave blank for pure local mode
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE=
# R2_PREFIX=
